{
    "name": "psgmrunner",
    "displayName": "psgmrunner",
    "description": "Preset, target, build, run, and debug workflow for CMake-based C++ projects.",
    "version": "0.0.1",
    "publisher": "local",
    "license": "MIT",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onWorkspaceContains:CMakePresets.json"
    ],
    "main": "./out/extension.js",
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.11.30",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.4.5"
    },
    "contributes": {
        "commands": [
            {
                "command": "myPlugin.refresh",
                "title": "CMake Runner: Refresh"
            },
            {
                "command": "myPlugin.selectPreset",
                "title": "CMake Runner: Select Preset"
            },
            {
                "command": "myPlugin.buildTarget",
                "title": "CMake Runner: Build Target"
            },
            {
                "command": "myPlugin.runTarget",
                "title": "CMake Runner: Run Target"
            },
            {
                "command": "myPlugin.debugTarget",
                "title": "CMake Runner: Debug Target"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "myPlugin",
                    "title": "psgmrunner",
                    "icon": "resources/cmake-runner.svg"
                }
            ]
        },
        "views": {
            "myPlugin": [
                {
                    "id": "myPlugin.presets",
                    "name": "Presets"
                },
                {
                    "id": "myPlugin.targets",
                    "name": "Targets"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "myPlugin.refresh",
                    "when": "view == myPlugin.presets || view == myPlugin.targets",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "myPlugin.selectPreset",
                    "when": "view == myPlugin.presets && viewItem == preset",
                    "group": "inline@1"
                },
                {
                    "command": "myPlugin.buildTarget",
                    "when": "view == myPlugin.targets && viewItem == target",
                    "group": "inline@1"
                },
                {
                    "command": "myPlugin.runTarget",
                    "when": "view == myPlugin.targets && viewItem == target",
                    "group": "inline@2"
                },
                {
                    "command": "myPlugin.debugTarget",
                    "when": "view == myPlugin.targets && viewItem == target",
                    "group": "inline@3"
                }
            ]
        },
        "configuration": {
            "title": "psgmrunner",
            "properties": {
                "myPlugin.tasks.buildCommandTemplate": {
                    "type": "string",
                    "default": "cmake --build ${buildDir} --config ${preset} --target ${target}",
                    "description": "Build command template. Supports ${buildDir}, ${preset}, ${target}, and ${sourceDir}."
                },
                "myPlugin.tasks.runCommandTemplate": {
                    "type": "string",
                    "default": "${buildDir}/${target}",
                    "description": "Run command template. Supports ${buildDir}, ${preset}, ${target}, and ${sourceDir}."
                },
                "myPlugin.tasks.clearTerminalBeforeRun": {
                    "type": "boolean",
                    "default": true,
                    "description": "Clear the shared terminal before starting a build or run task."
                }
            }
        }
    }
}