{
    "name": "cmakerunner",
    "displayName": "CMake Runner",
    "description": "Preset, target, build, run, and debug workflow for CMake-based C++ projects.",
    "version": "0.1.3",
    "publisher": "Simon-tools",
    "repository": {
        "type": "git",
        "url": "https://github.com/simonln/cmakerunner"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/simonln/cmakerunner/issues"
    },
    "homepage": "https://github.com/simonln/cmakerunner",
    "icon": "resources/cmake-runner.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onWorkspaceContains:CMakePresets.json"
    ],
    "main": "./out/src/extension.js",
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
        "compile": "npm run clean && node ./node_modules/typescript/bin/tsc -p ./",
        "watch": "node ./node_modules/typescript/bin/tsc -watch -p ./",
        "package:vsix": "npx @vscode/vsce package --allow-missing-repository",
        "test": "npm run compile && node test/run-unit.js",
        "test:watch": "npm run compile && node -r ./test/vscode-mock.js ./node_modules/mocha/bin/mocha --timeout 10000 'out/test/**/*.test.js' --watch"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.6",
        "@types/node": "^20.11.30",
        "@types/vscode": "^1.85.0",
        "c8": "^9.1.0",
        "mocha": "^10.4.0",
        "nyc": "^18.0.0",
        "typescript": "^5.4.5"
    },
    "contributes": {
        "commands": [
            {
                "command": "cmakerunner.refresh",
                "title": "Refresh"
            },
            {
                "command": "cmakerunner.selectPreset",
                "title": "Select Preset"
            },
            {
                "command": "cmakerunner.buildPreset",
                "title": "Build Preset",
                "icon": {
                    "light": "resources/build-light.svg",
                    "dark": "resources/build-dark.svg"
                }
            },
            {
                "command": "cmakerunner.rebuildPreset",
                "title": "Rebuild Preset",
                "icon": {
                    "light": "resources/rebuild-light.svg",
                    "dark": "resources/rebuild-dark.svg"
                }
            },
            {
                "command": "cmakerunner.buildTarget",
                "title": "Build Target",
                "icon": {
                    "light": "resources/build-target-light.svg",
                    "dark": "resources/build-target-dark.svg"
                }
            },
            {
                "command": "cmakerunner.buildTargetFromCurrentFile",
                "title": "Build Target From Current File",
                "icon": {
                    "light": "resources/build-target-light.svg",
                    "dark": "resources/build-target-dark.svg"
                }
            },
            {
                "command": "cmakerunner.filterTargets",
                "title": "Filter"
            },
            {
                "command": "cmakerunner.clearTargetFilter",
                "title": "Clear Filter"
            },
            {
                "command": "cmakerunner.runTarget",
                "title": "Run Target",
                "icon": {
                    "light": "resources/run-light.svg",
                    "dark": "resources/run-dark.svg"
                }
            },
            {
                "command": "cmakerunner.debugTarget",
                "title": "Debug Target",
                "icon": {
                    "light": "resources/debug-light.svg",
                    "dark": "resources/debug-dark.svg"
                }
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "cmakerunner",
                    "title": "CMake Runner",
                    "icon": "resources/cmake-runner.svg"
                }
            ]
        },
        "views": {
            "cmakerunner": [
                {
                    "id": "cmakerunner.presets",
                    "name": "Presets"
                },
                {
                    "id": "cmakerunner.targets",
                    "name": "Targets"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "cmakerunner.refresh",
                    "when": "view == cmakerunner.presets || view == cmakerunner.targets",
                    "group": "navigation"
                },
                {
                    "command": "cmakerunner.filterTargets",
                    "when": "view == cmakerunner.targets",
                    "group": "navigation@1"
                },
                {
                    "command": "cmakerunner.clearTargetFilter",
                    "when": "view == cmakerunner.targets && cmakerunner.targetsFilterActive",
                    "group": "navigation@2"
                }
            ],
            "editor/title": [
                {
                    "command": "cmakerunner.buildTargetFromCurrentFile",
                    "when": "resourceExtname == .cpp || resourceExtname == .c",
                    "group": "navigation@1"
                }
            ],
            "view/item/context": [
                {
                    "command": "cmakerunner.buildPreset",
                    "when": "view == cmakerunner.presets && viewItem == preset",
                    "group": "inline@1"
                },
                {
                    "command": "cmakerunner.rebuildPreset",
                    "when": "view == cmakerunner.presets && viewItem == preset",
                    "group": "inline@2"
                },
                {
                    "command": "cmakerunner.buildTarget",
                    "when": "view == cmakerunner.targets && viewItem == target",
                    "group": "inline@1"
                },
                {
                    "command": "cmakerunner.runTarget",
                    "when": "view == cmakerunner.targets && viewItem == target",
                    "group": "inline@2"
                },
                {
                    "command": "cmakerunner.debugTarget",
                    "when": "view == cmakerunner.targets && viewItem == target",
                    "group": "inline@3"
                }
            ]
        },
        "configuration": {
            "title": "cmakerunner",
            "properties": {
                "cmakerunner.cmakePath": {
                    "type": "string",
                    "default": "",
                    "description": "Optional path to cmake executable used for preset discovery (for example a Visual Studio bundled CMake path). Leave empty to use automatic detection."
                },
                "cmakerunner.tasks.presetConfigureCommandTemplate": {
                    "type": "string",
                    "default": "cmake --preset ${preset}",
                    "description": "Preset configure command template. Supports ${buildDir}, ${preset}, and ${sourceDir}. The default also enables compile_commands.json generation."
                },
                "cmakerunner.tasks.buildCommandTemplate": {
                    "type": "string",
                    "default": "cmake --build ${buildDir}${configurationArgument} --target ${target}",
                    "description": "Build command template. Supports ${buildDir}, ${preset}, ${target}, ${sourceDir}, ${buildPreset}, ${configuration}, ${configurationArgument}, ${buildPresetArgument}, ${executablePath}, ${quotedExecutablePath}, and ${executableCommand}."
                },
                "cmakerunner.tasks.runCommandTemplate": {
                    "type": "string",
                    "default": "${executableCommand}",
                    "description": "Run command template. Supports ${buildDir}, ${preset}, ${target}, ${sourceDir}, ${buildPreset}, ${configuration}, ${configurationArgument}, ${buildPresetArgument}, ${executablePath}, ${quotedExecutablePath}, and ${executableCommand}."
                },
                "cmakerunner.tasks.clearTerminalBeforeRun": {
                    "type": "boolean",
                    "default": true,
                    "description": "Clear the shared terminal before starting a build or run task."
                },
                "cmakerunner.debug.type": {
                    "type": "string",
                    "default": "",
                    "description": "Debug configuration type written into launch.json. Leave empty to use the platform default: cppvsdbg on Windows, cppdbg/lldb on other platforms."
                }
            }
        }
    }
}
